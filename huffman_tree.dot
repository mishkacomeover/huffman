digraph HuffmanTree {
    node [fontname="Impact"];

    node0 [shape=circle, label="5"];
    node1 [shape=circle, label="2"];
    node3 [shape=box, label="z\nf=1"];
    node1 -> node3 [label="0"];
    node4 [shape=box, label="d\nf=1"];
    node1 -> node4 [label="1"];
    node0 -> node1 [label="0"];
    node2 [shape=circle, label="3"];
    node9 [shape=box, label="a\nf=1"];
    node2 -> node9 [label="0"];
    node10 [shape=circle, label="2"];
    node13 [shape=box, label="p\nf=1"];
    node10 -> node13 [label="0"];
    node14 [shape=box, label="i\nf=1"];
    node10 -> node14 [label="1"];
    node2 -> node10 [label="1"];
    node0 -> node2 [label="1"];
}
